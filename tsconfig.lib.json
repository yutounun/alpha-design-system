{
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": [
        "src/index.ts",
        "src/lib/**/*.ts",
        "src/components/**/*.ts",
        "src/components/**/*.tsx"
    ],
    "exclude": [
        "**/*.stories.tsx",
        "**/*.mdx",
        "src/docs/**",
        "src/vite-env.d.ts"
    ]
}
