{
    "name": "alpha-design-system",
    "version": "0.1.0",
    "packageManager": "pnpm@10.30.3",
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist",
        "src/styles/theme.css",
        "README.md",
        "LICENSE"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "build:app": "tsc -b && vite build",
        "build:lib": "node scripts/build-registry.mjs && BUILD_MODE=lib vite build",
        "registry:build": "node scripts/build-registry.mjs && shadcn build",
        "build": "pnpm run build:lib && pnpm run registry:build && pnpm run build-storybook",
        "lint": "eslint .",
        "prepare": "git config core.hooksPath .githooks || true",
        "preview": "vite preview",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test:storybook": "vitest run --project=storybook",
        "typecheck": "tsc -b",
        "changeset": "changeset",
        "version": "changeset version && pnpm install --lockfile-only",
        "release": "pnpm run build:lib && changeset publish"
    },
    "peerDependencies": {
        "react": ">=18.0.0 <20.0.0",
        "react-dom": ">=18.0.0 <20.0.0",
        "tailwindcss": "^4.2.0"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.577.0",
        "radix-ui": "^1.4.3",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@chromatic-com/storybook": "^5.1.2",
        "@eslint/css": "^1.0.0",
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^1.2.0",
        "@eslint/markdown": "^7.5.1",
        "@fontsource-variable/geist": "^5.2.8",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-onboarding": "^10.3.5",
        "@storybook/addon-vitest": "^10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@tailwindcss/postcss": "^4",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/browser-playwright": "^4.1.4",
        "@vitest/coverage-v8": "^4.1.4",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.4",
        "eslint-config-next": "16.2.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-storybook": "^10.3.5",
        "ffmpeg-static": "^5.3.0",
        "globals": "^17.4.0",
        "next": "16.2.0",
        "playwright": "^1.59.1",
        "prettier": "3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "shadcn": "^4.2.0",
        "sonner": "^2.0.7",
        "storybook": "^10.3.5",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.0",
        "vaul": "^1.1.2",
        "vite": "^8.0.4",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.4",
        "zod": "^4.3.6"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./styles.css": "./src/styles/theme.css",
        "./package.json": "./package.json",
        "./button": {
            "types": "./dist/components/button/index.d.ts",
            "import": "./dist/components/button/button.js"
        },
        "./form-field": {
            "types": "./dist/components/form-field/index.d.ts",
            "import": "./dist/components/form-field/form-field.js"
        },
        "./input": {
            "types": "./dist/components/input/index.d.ts",
            "import": "./dist/components/input/input.js"
        },
        "./label": {
            "types": "./dist/components/label/index.d.ts",
            "import": "./dist/components/label/label.js"
        },
        "./tabs": {
            "types": "./dist/components/tabs/index.d.ts",
            "import": "./dist/components/tabs/tabs.js"
        },
        "./textarea": {
            "types": "./dist/components/textarea/index.d.ts",
            "import": "./dist/components/textarea/textarea.js"
        }
    }
}
